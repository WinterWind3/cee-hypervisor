# Example environment variables for cee-backend
# Copy this file to `.env` and adjust values before starting containers.

# Secret key for the application
SECRET_KEY=change-me-in-production

# Database (compose sets this by default)
# DATABASE_URL=postgresql://cee:cee123@postgres:5432/cee

# If you bind-mount the host libvirt socket into the container, set LIBVIRT_URI to use the system socket
LIBVIRT_URI=qemu:///system
IMAGES_PATH=/var/lib/libvirt/images

# UID:GID to run the backend container process as (so it can access /run/libvirt/libvirt-sock)
# Find values on the host:
#  stat -c '%u %g' /run/libvirt/libvirt-sock
#  getent group libvirt
# Example (replace with values from your host):
BACKEND_UID=0
BACKEND_GID=0

# noVNC host/port if needed
NOVNC_HOST=localhost
NOVNC_PORT=6080
LIBVIRT_VNC_HOST=127.0.0.1
NOVNC_TOKEN_FILE=/app/data/novnc/tokens

# Optional: override default uvicorn port when running locally
#BACKEND_PORT=8000
